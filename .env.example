# AutoBroker Ethiopia — Environment Configuration
# Copy this file to .env and fill in the values

# ─── Authentication (REQUIRED in production) ───────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET="change-me-to-a-long-random-secret-in-production"

# ─── Database (leave unset to use in-memory demo mode) ─────────────────────
# DB_HOST="localhost"
# DB_USER="root"
# DB_PASSWORD=""
# DB_DATABASE="autobroker_ethiopia"

# ─── MongoDB (alternative to MySQL) ────────────────────────────────────────
# MONGODB_URI="mongodb://localhost:27017/autobroker_ethiopia"

# ─── App Hosting URL ────────────────────────────────────────────────────────
APP_URL="http://localhost:3000"

# ─── Runtime flags ──────────────────────────────────────────────────────────
# NODE_ENV="production"   # Set to production when deploying
# VERCEL=1                # Vercel sets this automatically — do not modify
