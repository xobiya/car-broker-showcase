# AutoBroker Ethiopia — Environment Configuration

# ─── Authentication ───────────────────────────────────────────────
JWT_SECRET="change-me-to-a-long-random-secret-in-production"

# ─── Database (MongoDB) ────────────────────────────────────────────
MONGODB_URI="mongodb://localhost:27017/autobroker_ethiopia"

# ─── Cloudinary (Image/File Upload) ────────────────────────────────
CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""

# ─── SMTP (Email Notifications) ────────────────────────────────────
SMTP_HOST=""
SMTP_PORT="587"
SMTP_SECURE="false"
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM="noreply@autobroker.et"

# ─── App Hosting URL ────────────────────────────────────────────────
APP_URL="http://localhost:3000"

# ─── Runtime flags ──────────────────────────────────────────────────
NODE_ENV="development"
