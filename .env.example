# AutoBroker Ethiopia - Environment Configuration

# Database Credentials (leave unset to use in-memory demo mode)
# DB_HOST="localhost"
# DB_USER="root"
# DB_PASSWORD=""
# DB_DATABASE="autobroker_ethiopia"

# Gemini AI API Key - Required for the AI Sourcing Concierge chat feature
# Get your API key at https://aistudio.google.com/apikey
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# App Hosting URL - Used for self-referential links
APP_URL="http://localhost:3000"

# Vercel sets this automatically during deployment (do not modify)
# VERCEL=1
